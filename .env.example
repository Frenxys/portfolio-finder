# Optional but strongly recommended — raises GitHub API rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=

# Search interval in milliseconds (default: 60000 = 1 minute)
SEARCH_INTERVAL_MS=60000

# Port for the web server (default: 3000)
PORT=3000

# Minimum stars per repo (default: 5)
MIN_STARS=5

# Maximum stars per repo (default: 5000)
MAX_STARS=5000

# Only include repos pushed within this many days (default: 180)
PUSHED_WITHIN_DAYS=180
